# Storefront environment configuration.
# Copy to `.env.local` and adjust as needed.

# Base URL the in-browser API client calls. Leave as "/api" to use the
# Vite dev proxy (see vite.config.ts). In production behind the ingress,
# this is also "/api" since the app is served same-origin.
VITE_API_BASE_URL=/api

# OPTIONAL — single proxy target for the Vite dev server.
# Unset  -> dev proxy fans /api/<ctx> out to each service on localhost
#           (8081-8087), matching docker-compose / local `mvn spring-boot:run`.
# Set    -> dev proxy sends ALL /api/* to this one origin, matching the
#           real NGINX ingress. Example:
# VITE_API_PROXY_TARGET=https://ecommerce.local
